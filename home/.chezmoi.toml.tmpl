{{- $email := promptStringOnce . "email" "Git email" "me@geoffwhatley.com" -}}
{{- $gui := promptBoolOnce . "gui" "Has a GUI/desktop session" -}}

{{- /* detect WSL via the kernel release string (on darwin .chezmoi.kernel
       exists but has no osrelease key, so check for the key itself) */ -}}
{{- $wsl := false -}}
{{- if and (hasKey .chezmoi "kernel") (hasKey .chezmoi.kernel "osrelease") -}}
{{-   $wsl = .chezmoi.kernel.osrelease | lower | contains "microsoft" -}}
{{- end -}}

{{- $arch := false -}}
{{- if hasKey .chezmoi "osRelease" -}}
{{-   $arch = eq (get .chezmoi.osRelease "id" | default "") "arch" -}}
{{- end -}}

sourceDir = {{ joinPath .chezmoi.homeDir "projects/dotfiles" | quote }}

encryption = "age"
[age]
    identity = "{{ .chezmoi.homeDir }}/.config/chezmoi/key.txt"
    recipient = "age1t52fcvp9dek936uwju5trk5suuta459euh4w3rzhkszdpmyuyvlq4z4zln"

[data]
    email = {{ $email | quote }}
    gui = {{ $gui }}
    wsl = {{ $wsl }}
    arch = {{ $arch }}

[git]
    autoAdd = true
    # autoCommit/autoPush deliberately off: public repo, commit and push by hand

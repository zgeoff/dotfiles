# add our non-platform specific directories to our path
path=(
  "$HOME/.fly/bin"
  /usr/local/{bin,sbin}
  $path
)

ASDF_DIR="$HOME/.asdf"

# load `asdf`, our version manager
if [ -d "$ASDF_DIR" ]; then
  . "$ASDF_DIR/plugins/golang/set-env.zsh"

  path=(
    "$ASDF_DIR/shims"
    $path
  )
fi

# add our ZSH functions to our path
fpath=(
  "$HOME/.zfuncs"
  "$HOME/.zcompcache"
  $fpath
)
